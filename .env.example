# Modelo de variáveis de ambiente. Copie para .env e preencha.
# (.env está no .gitignore e nunca é versionado.)

# Banco de dados.
# Produção usa Postgres no Neon; local (docker-compose) usa o serviço "db".
DATABASE_URL=postgresql://minha_vida:minha_vida@db:5432/minha_vida

# WhatsApp Cloud API (Meta). Preencha com credenciais reais para enviar mensagens.
API_VERSION=v20.0
PHONE_NUMBER_ID=
ACCESS_TOKEN=
VERIFY_TOKEN=
